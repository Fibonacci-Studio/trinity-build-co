---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Page Not Found — Trinity Build Co." noindex>
  <Nav active="none" />
  <main id="main-content">
    <section class="nf">
      <div class="container nf-inner">
        <div class="eyebrow nf-eyebrow"><span>404 — Page Not Found</span></div>
        <h1 class="page-title">This page hasn't been built yet.</h1>
        <p class="nf-copy">
          The page you're looking for doesn't exist or has moved. Let's get you back on solid
          ground.
        </p>
        <div class="nf-actions">
          <a href="/" class="btn btn--sage">Back to Home</a>
          <a href="/contact" class="btn btn--outline">Contact Us</a>
        </div>
      </div>
    </section>
  </main>
  <Footer showCta={false} />
</Base>

<style>
  .nf {
    background: var(--color-ink);
    padding: clamp(96px, 14vh, 160px) 0;
  }

  .nf-eyebrow {
    margin-bottom: 28px;
  }

  .nf-copy {
    margin: 28px 0 0;
    font-size: 18px;
    line-height: 1.75;
    color: var(--color-dust-muted);
    max-width: 560px;
  }

  .nf-actions {
    display: flex;
    gap: 16px;
    margin-top: 44px;
    flex-wrap: wrap;
  }
</style>
