const deliveryItems = [
  {
    title: "Consistent Unit Standards",
    copy: "Approved benchmarks and repeatable field verification reduce finish drift as crews move through buildings and unit types.",
  },
  {
    title: "Occupancy-Driven Milestones",
    copy: "Work is organized around inspections, leasing priorities, amenity readiness, and practical building turnover dates.",
  },
  {
    title: "Coordinated Trade Flow",
    copy: "Crews, material deliveries, and inspections are sequenced to protect production without sacrificing quality or safety.",
