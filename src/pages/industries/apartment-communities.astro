<IndustryDetailPage
  title="Apartment Communities"
  seoDescription="Apartment community construction services in Phoenix and across Arizona, from planning and building phasing through unit quality control, amenities, and turnover."
  eyebrow="Apartment Construction"
  lede="Coordinated delivery for apartment buildings, resident amenities, site improvements, and phased occupancy across Arizona."
  heroImage={heroImage}
  heroAlt="Trinity Build Co. team overseeing an apartment community under construction in Phoenix"
  heroPosition="center 48%"
  introTitle="Built around quality at every unit."
  introParagraphs={[
    "Apartment communities combine the complexity of repeated residential units with the demands of commercial scheduling, shared infrastructure, amenities, inspections, and phased occupancy. Each part must move together without losing control of the details.",
    "Trinity Build Co. manages that work with clear benchmarks, building-level schedules, proactive coordination, and transparent reporting so ownership can track progress from the first unit through community closeout.",
  ]}
  capabilities={capabilities}
  supportImage={supportImage}
  supportAlt="Trinity Build Co. crew installing a modern commercial building facade in Phoenix"
  supportPosition="center 52%"
  supportEyebrow="Quality at Scale"
  supportTitle="A consistent standard from the first unit to the last."
  supportCopy="Mockups, first-unit approvals, structured inspections, and disciplined punch management create repeatable quality across buildings, floor plans, and resident-facing spaces."
  deliveryTitle="Turnover planned from day one."
  deliveryCopy="Occupancy dates become more dependable when inspections, corrections, amenities, documentation, and owner acceptance are built into the schedule early."
