const capabilities = [
  {
    title: "Planning & Unit Coordination",
    copy: "Unit mix, finish standards, long-lead decisions, logistics, and jurisdictional requirements coordinated before construction begins.",
  },
  {
    title: "Sitework & Building Phasing",
    copy: "Horizontal improvements and vertical starts planned to maintain trade flow and support practical occupancy milestones.",
