---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ContactRows from "../components/ContactRows.astro";
import { business } from "../config";
import heroPhoto from "../assets/photos/16-night-commercial-jobsite.png";
import multiFamilyPhoto from "../assets/photos/work-areas/01-multi-family-developments.png";
import apartmentPhoto from "../assets/photos/work-areas/02-apartment-communities.png";
import mixedUsePhoto from "../assets/photos/work-areas/03-mixed-use-developments.png";
import officePhoto from "../assets/photos/work-areas/04-office-buildings.png";
import campusPhoto from "../assets/photos/work-areas/05-commercial-campuses.png";

const capabilities = [
  "Ground-Up Construction",
  "Tenant Improvements",
  "Design-Build & Construction Management",
];

const services = [
  {
    title: "Commercial General Contracting",
    copy: "Full-scope delivery of commercial projects, managed with precision from permit to closeout.",
  },
  {
    title: "Design-Build",
    copy: "A single accountable team from concept through completion — faster decisions, fewer change orders.",
  },
  {
    title: "Construction Management",
    copy: "Owner-side leadership that protects budget, schedule, and quality at every phase.",
  },
  {
    title: "Preconstruction Services",
    copy: "Planning, budget development, scheduling, value engineering, and hands-on management before construction begins.",
  },
  {
    title: "Budget Development",
    copy: "Accurate, transparent budgets built early — and defended through delivery.",
  },
  {
    title: "Value Engineering",
    copy: "Smart alternatives that reduce cost without compromising design intent or quality.",
  },
  {
    title: "Project Planning",
    copy: "Realistic schedules, clear milestones, and proactive coordination across every trade.",
  },
  {
    title: "Ground-Up Construction",
    copy: "New commercial construction delivered on time, on budget, and built to last.",
  },
  {
    title: "Tenant Improvements",
    copy: "Fast-track interior buildouts that minimize downtime for tenants and owners.",
  },
];

const processSteps = [
  { title: "Discover", copy: "We understand your goals, vision, and priorities." },
  { title: "Plan", copy: "We develop the right strategy, budget, and timeline." },
  { title: "Collaborate", copy: "We align the right team and solve challenges early." },
  { title: "Build", copy: "We execute with precision, quality, and proactive communication." },
  { title: "Deliver", copy: "We complete with thorough closeout and a seamless turnover." },
  { title: "Support", copy: "We remain a trusted partner long after completion." },
];

const priorityIndustries = [
  {
    title: "Multi-Family Developments",
    slug: "multi-family-developments",
    href: "/industries/multi-family-developments",
    image: multiFamilyPhoto,
    alt: "Trinity Build Co. team at a branded multi-family development jobsite in Phoenix",
  },
  {
    title: "Apartment Communities",
    slug: "apartment-communities",
    href: "/industries/apartment-communities",
    image: apartmentPhoto,
    alt: "Trinity Build Co. team overseeing an apartment community under construction in Phoenix",
  },
  {
    title: "Mixed-Use Developments",
    slug: "mixed-use-developments",
    href: "/industries#mixed-use-developments",
    image: mixedUsePhoto,
    alt: "Trinity Build Co. team at a mixed-use development under construction in Phoenix",
  },
  {
    title: "Office Buildings",
    slug: "office-buildings",
    href: "/industries#office-buildings",
    image: officePhoto,
    alt: "Trinity Build Co. team at a commercial office building jobsite in Phoenix",
  },
  {
    title: "Commercial Campuses",
    slug: "commercial-campuses",
    href: "/industries#commercial-campuses",
    image: campusPhoto,
    alt: "Trinity Build Co. team at a commercial campus under construction in Phoenix",
  },
];

const additionalIndustries = [
  "Medical",
  "Industrial",
  "Warehouses",
  "Retail",
  "Restaurants",
  "Churches",
  "Commercial Condominiums",
  "Tenant Improvements",
];

const values = [
  "Integrity",
  "Excellence",
  "Relationships",
  "Stewardship",
  "Innovation",
  "Teamwork",
  "Safety",
  "Accountability",
];

const whyItems = [
  "Disciplined Preconstruction",
  "Financial Stewardship",
  "Transparent Communication",
  "Experienced Leadership",
  "Quality Without Compromise",
  "Technology & Modern Systems",
  "Safety First",
  "Long-Term Partnerships",
];

const contactRows = [
  { label: "Phone", value: business.phone, href: business.phoneHref },
  { label: "Email", value: business.email, href: `mailto:${business.email}` },
  { label: "Office", value: business.addressLabel },
  { label: "License", value: business.rocLicense },
];
---

<Base
  title="Trinity Build Co. — Commercial General Contractor | Phoenix, Arizona"
  description="Ground-up commercial construction, tenant improvements, and design-build across Arizona — delivered with disciplined preconstruction, transparent budgets, and institutional rigor."
>
  <Nav active="home" />
  <main id="main-content">
    <!-- ============ HERO ============ -->
    <section id="top" class="hero">
      <div class="hero-bg" aria-hidden="true">
        <Image
          src={heroPhoto}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          quality={72}
          class="hero-img"
        />
        <div class="hero-scrim hero-scrim--x"></div>
        <div class="hero-scrim hero-scrim--y"></div>
      </div>
      <div class="container hero-inner">
        <div class="eyebrow"><span>Commercial General Contractor — Phoenix, Arizona</span></div>
        <h1 class="hero-title">Building Excellence.<br /><span>Delivering Trust.</span></h1>
        <p class="hero-lede">
          Ground-up commercial construction, tenant improvements, and design-build — delivered
          with the discipline, transparency, and financial rigor of an institutional partner.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn--sage">Start Your Project</a>
          <a href="#services" class="btn btn--outline">View Our Capabilities</a>
        </div>
        <div class="hero-caps">
          {
            capabilities.map((cap, i) => (
              <div class="hero-cap">
                <span class="cap-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="cap-label">{cap}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ INDUSTRIES ============ -->
    <section id="industries" class="industries">
      <div class="container">
        <div class="section-head">
          <div data-reveal>
            <div class="eyebrow head-eyebrow"><span>Where We Build</span></div>
            <h2 class="section-title dark-on-light">Industries We Serve</h2>
          </div>
          <div class="head-side" data-reveal>
            <p>Purpose-built experience across the commercial sectors driving Arizona's growth.</p>
            <a href="/industries" class="arrow-link arrow-link--dark head-link">All Industries →</a>
          </div>
        </div>
        <div class="focus-grid">
          {
            priorityIndustries.map((industry) => (
              <a
                href={industry.href}
                class="focus-card"
                aria-label={`Learn about ${industry.title}`}
                data-reveal
              >
                <Image
                  src={industry.image}
                  alt={industry.alt}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 900px) 40vw, (min-width: 560px) 50vw, 100vw"
                  quality={75}
                  class="focus-img"
                />
                <span class="focus-scrim" aria-hidden="true" />
                <span class="focus-content">
                  <span class="focus-kicker">Commercial Sector</span>
                  <span class="focus-title">{industry.title}</span>
                  <span class="focus-link">Explore Sector →</span>
                </span>
              </a>
            ))
          }
        </div>
        <div class="additional-head" data-reveal>
          <span>Additional Commercial Sectors</span>
        </div>
        <div class="tile-grid industries-grid">
          {
            additionalIndustries.map((industry) => (
              <div class="industry-tile" data-reveal>
                <span class="industry-dot" aria-hidden="true" />
                <span class="industry-label">{industry}</span>
              </div>
            ))
          }
          <a href="#contact" class="industry-cta" data-reveal>
            <span class="industry-cta-hint">Have a project in mind?</span>
            <span class="industry-cta-link">Let's Talk →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section id="about" class="about">
      <div class="container">
        <div class="about-grid">
          <div data-reveal>
            <div class="eyebrow about-eyebrow"><span>Who We Are</span></div>
            <h2 class="section-title about-title">More than a general contractor.</h2>
          </div>
          <div data-reveal>
            <p class="about-copy">
              Trinity Build Co. is a Phoenix-based commercial general contractor serving owners,
              developers, and institutions across Arizona. We deliver ground-up construction,
              tenant improvements, and design-build projects with the rigor of a premier
              development firm — disciplined preconstruction, financial stewardship, and execution
              without surprises.
            </p>
            <p class="about-copy about-copy--follow">
              We build more than buildings. We build confidence, opportunity, and a legacy of
              trust — through projects that strengthen businesses, communities, and the people we
              serve.
            </p>
            <a href="/about" class="arrow-link arrow-link--dark about-link">Our Story →</a>
          </div>
        </div>
        <div class="mission-grid">
          <div class="mission-card" data-reveal>
            <div class="kicker">Our Mission</div>
            <p>
              To build exceptional commercial spaces through integrity, disciplined execution, and
              lasting relationships — delivering projects that strengthen businesses, communities,
              and the people we serve.
            </p>
          </div>
          <div class="mission-card" data-reveal>
            <div class="kicker">Our Vision</div>
            <p>
              To become Arizona's most trusted commercial builder — recognized for excellence in
              preconstruction, quality craftsmanship, financial stewardship, and long-term
              partnership.
            </p>
          </div>
        </div>
        <div class="values-strip">
          {
            values.map((value) => (
              <span class="value-item">
                <span class="value-dot" aria-hidden="true" />
                <span class="value-label">{value}</span>
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section id="services" class="services">
      <div class="container">
        <div class="section-head">
          <div data-reveal>
            <div class="eyebrow head-eyebrow"><span>What We Do</span></div>
            <h2 class="section-title dark-on-light">Commercial Construction Services</h2>
          </div>
          <div class="head-side" data-reveal>
            <p>From first budget to final closeout — one accountable team, one standard of excellence.</p>
            <a href="/services" class="arrow-link arrow-link--dark head-link">All Services →</a>
          </div>
        </div>
        <div class="tile-grid services-grid">
          {
            services.map((service, i) => (
              <div class="service-card" data-reveal>
                <div class="num">{String(i + 1).padStart(2, "0")}</div>
                <h3>{service.title}</h3>
                <p>{service.copy}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ PROCESS ============ -->
    <section id="process" class="process">
      <div class="container">
        <div class="section-head">
          <div data-reveal>
            <div class="eyebrow head-eyebrow"><span>Our Process</span></div>
            <h2 class="section-title light-on-dark">The Trinity Way</h2>
          </div>
          <div class="head-side head-side--process" data-reveal>
            <p>
              A proven six-step process that ensures predictable outcomes and exceptional results —
              on every project, at every phase.
            </p>
            <a href="/process" class="arrow-link arrow-link--light head-link">The Full Process →</a>
          </div>
        </div>
        <div class="tile-grid tile-grid--dark process-grid">
          {
            processSteps.map((step, i) => (
              <div class="process-card" data-reveal>
                <div class="num">{String(i + 1).padStart(2, "0")}</div>
                <h3>{step.title}</h3>
                <p>{step.copy}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ WHY TRINITY ============ -->
    <section id="why" class="why">
      <div class="container why-grid">
        <div data-reveal>
          <div class="eyebrow head-eyebrow"><span>Why Trinity</span></div>
          <h2 class="section-title dark-on-light">Why owners choose us.</h2>
          <p class="why-copy">
            We treat every dollar, day, and decision as our own. Preconstruction is disciplined,
            budgets are transparent, schedules are honest — and our leadership stays engaged from
            first meeting to final walkthrough.
          </p>
          <a href="#contact" class="arrow-link arrow-link--dark why-link">Schedule a Consultation →</a>
        </div>
        <div class="why-list" data-reveal>
          {
            whyItems.map((item) => (
              <div class="why-item">
                <span class="why-check" aria-hidden="true">✓</span>
                <span class="why-label">{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ PORTFOLIO ============ -->
    <section id="portfolio" class="portfolio">
      <div class="container">
        <div class="section-head">
          <div data-reveal>
            <div class="eyebrow head-eyebrow"><span>Commercial Focus</span></div>
            <h2 class="section-title dark-on-light">Project Types We Build</h2>
          </div>
          <div class="head-side" data-reveal>
            <p>Representative imagery for the commercial work we pursue across Arizona.</p>
            <a href="/portfolio" class="arrow-link arrow-link--dark head-link">View Project Types →</a>
          </div>
        </div>
        <div class="portfolio-grid">
          <a
            href="/industries/multi-family-developments"
            class="portfolio-item"
            aria-label="Explore Multi-Family Developments"
            data-reveal
          >
            <Image
              src={multiFamilyPhoto}
              alt="Trinity Build Co. team at a multi-family development under construction in Phoenix"
              widths={[640, 1000, 1400]}
              sizes="(min-width: 900px) 56vw, 100vw"
              quality={75}
              class="portfolio-img portfolio-img--featured"
            />
            <div class="portfolio-caption">
              <span class="caption-title">Multi-Family Developments</span>
              <span class="caption-loc">Phoenix, AZ</span>
            </div>
          </a>
          <div class="portfolio-col">
            <a
              href="/industries/apartment-communities"
              class="portfolio-item"
              aria-label="Explore Apartment Communities"
              data-reveal
            >
              <Image
                src={apartmentPhoto}
                alt="Trinity Build Co. team overseeing an apartment community under construction in Phoenix"
                widths={[480, 800, 1200]}
                sizes="(min-width: 900px) 42vw, 100vw"
                quality={75}
                class="portfolio-img portfolio-img--stack"
              />
              <div class="portfolio-caption">
                <span class="caption-title">Apartment Communities</span>
                <span class="caption-loc">Phoenix, AZ</span>
              </div>
            </a>
            <a
              href="/industries#mixed-use-developments"
              class="portfolio-item"
              aria-label="Explore Mixed-Use Developments"
              data-reveal
            >
              <Image
                src={mixedUsePhoto}
                alt="Trinity Build Co. team at a mixed-use development under construction in Phoenix"
                widths={[480, 800, 1200]}
                sizes="(min-width: 900px) 42vw, 100vw"
                quality={75}
                class="portfolio-img portfolio-img--stack"
              />
              <div class="portfolio-caption">
                <span class="caption-title">Mixed-Use Developments</span>
                <span class="caption-loc">Phoenix, AZ</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CONTACT ============ -->
    <section id="contact" class="contact">
      <div class="container contact-grid">
        <div data-reveal>
          <div class="eyebrow head-eyebrow"><span>Start Your Project</span></div>
          <h2 class="section-title light-on-dark">Let's build something that lasts.</h2>
          <p class="contact-copy">
            Tell us about your project and a member of our leadership team will respond within one
            business day.
          </p>
          <ContactRows rows={contactRows} />
        </div>
        <div data-reveal>
          <ContactForm rows={5} />
        </div>
      </div>
    </section>
  </main>
  <Footer showCta={false} />
</Base>

<style>
  section {
    scroll-margin-top: 80px;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    background: var(--color-ink);
    color: #ffffff;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    display: block;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
  }

  .hero-scrim--x {
    background: linear-gradient(
      90deg,
      rgba(13, 13, 13, 0.96) 0%,
      rgba(13, 13, 13, 0.82) 42%,
      rgba(13, 13, 13, 0.42) 100%
    );
  }

  .hero-scrim--y {
    background: linear-gradient(
      180deg,
      rgba(13, 13, 13, 0.6) 0%,
      rgba(13, 13, 13, 0) 32%,
      rgba(13, 13, 13, 0.2) 72%,
      rgba(13, 13, 13, 0.92) 100%
    );
  }

  .hero-inner {
    position: relative;
    padding-top: clamp(90px, 13vh, 160px);
  }

  .hero-inner .eyebrow {
    margin-bottom: 30px;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(48px, 5.6vw, 78px);
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.08;
    max-width: 900px;
  }

  .hero-title span {
    color: var(--color-gold);
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: clamp(34px, 9.2vw, 38px);
    }
  }

  .hero-lede {
    margin: 32px 0 0;
    font-size: 18px;
    line-height: 1.75;
    color: var(--color-dust);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 44px;
    flex-wrap: wrap;
  }

  .hero-caps {
    margin-top: clamp(70px, 10vh, 120px);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: 32px;
    padding: 28px 0 38px;
  }

  .hero-cap {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .cap-num {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-gold);
  }

  .cap-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dust-bright);
  }

  @media (max-width: 700px) {
    .hero-inner {
      padding-top: 56px;
    }

    .hero-inner .eyebrow {
      margin-bottom: 22px;
    }

    .hero-lede {
      margin-top: 22px;
      font-size: 16px;
      line-height: 1.65;
    }

    .hero-actions {
      gap: 10px;
      margin-top: 28px;
    }

    .hero-caps {
      margin-top: 36px;
      gap: 14px;
      padding: 20px 0 24px;
    }
  }

  @media (max-width: 520px) {
    .hero-inner {
      padding-top: 44px;
    }

    .hero-lede {
      margin-top: 18px;
      font-size: 15.5px;
      line-height: 1.6;
    }

    .hero-actions {
      margin-top: 22px;
    }

    .hero-actions .btn {
      width: 100%;
      padding: 14px 18px;
      font-size: 12px;
    }

    .hero-caps {
      display: none;
    }
  }

  /* ── Shared section furniture ── */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 48px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .head-eyebrow {
    margin-bottom: 24px;
  }

  .dark-on-light {
    color: var(--color-ink);
  }

  .light-on-dark {
    color: #ffffff;
  }

  .head-side {
    max-width: 360px;
  }

  .head-side p {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-stone-muted);
  }

  .head-side--process {
    max-width: 380px;
  }

  .head-side--process p {
    color: var(--color-dust-muted);
  }

  .head-link {
    margin-top: 16px;
  }

  /* ── About ── */
  .about {
    background: #ffffff;
    padding: var(--section-pad) 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(400px, 100%), 1fr));
    gap: 64px;
    align-items: start;
  }

  .about-eyebrow {
    margin-bottom: 24px;
  }

  .about-title {
    color: var(--color-ink);
  }

  .about-copy {
    margin: 0;
    font-size: 17px;
    line-height: 1.8;
    color: var(--color-stone);
  }

  .about-copy--follow {
    margin-top: 20px;
  }

  .about-link {
    margin-top: 28px;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(400px, 100%), 1fr));
    gap: 24px;
    margin-top: 72px;
  }

  .mission-card {
    background: var(--color-cream);
    padding: 46px 48px;
  }

  @media (max-width: 560px) {
    .mission-card {
      padding: 36px 28px;
    }
  }

  .mission-card .kicker {
    margin-bottom: 18px;
  }

  .mission-card p {
    margin: 0;
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-char);
  }

  .values-strip {
    margin-top: 72px;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 26px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 18px 40px;
    justify-content: space-between;
    align-items: center;
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .value-dot {
    width: 6px;
    height: 6px;
    background: var(--color-sage);
  }

  .value-label {
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-char);
  }

  /* ── Services ── */
  .services {
    background: var(--color-cream);
    padding: var(--section-pad) 0;
  }

  .services-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
  }

  .service-card {
    background: #ffffff;
    padding: 38px 34px;
    transition: background 0.2s;
  }

  .service-card:hover {
    background: var(--color-cream-hover);
  }

  .service-card h3 {
    margin: 16px 0 10px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .service-card p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-stone-muted);
  }

  /* ── Process ── */
  .process {
