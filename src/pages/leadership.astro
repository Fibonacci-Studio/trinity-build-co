---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import logoIcon from "../assets/logo-icon.png";

const bio = [
  "Slade Gibson is the Founder and President of Trinity Build Co., providing strategic leadership for the company's commercial construction operations throughout Arizona. With over 25 years of experience in the construction industry, Slade has built a reputation for integrity, disciplined execution, and lasting client relationships.",
  "He works closely with owners, developers, architects, and project teams from preconstruction through project completion, ensuring every project is thoughtfully planned, professionally managed, and successfully delivered. His leadership is rooted in accountability, proactive communication, and a commitment to creating value for every client.",
  "Under Slade's leadership, Trinity Build Co. delivers commercial construction services with a focus on quality, collaboration, and long-term partnerships. The company is committed to helping clients navigate complex projects with confidence through careful planning, transparent communication, and dependable execution.",
  "Slade believes the strongest projects are built on trust, shared goals, and a commitment to doing the right thing. Those principles continue to shape the culture of Trinity Build Co. and guide every project the company undertakes.",
];
---

<Base
  title="Leadership — Trinity Build Co."
  description="Slade Gibson, President & CEO of Trinity Build Co., brings over 25 years of construction experience and a reputation for integrity, disciplined execution, and lasting client relationships."
>
  <Nav active="none" />
  <main id="main-content">
    <PageHero
      eyebrow="The People"
      title="Leadership."
      lede="Senior leadership stays engaged on every project. These are the people who answer the phone — from first meeting to final walkthrough."
    />

    <section class="leader">
      <div class="container leader-grid">
        <div class="leader-portrait" data-reveal>
          <div class="portrait-slot">
            <Image
              src={logoIcon}
              alt=""
              width={130}
              height={79}
              densities={[1, 2]}
              class="portrait-mark"
            />
          </div>
        </div>
        <div data-reveal>
          <div class="leader-kicker">
            <span class="kicker-dash" aria-hidden="true"></span>
            <span class="kicker">President & CEO</span>
          </div>
          <h2 class="leader-name">Slade Gibson</h2>
          {bio.map((paragraph) => <p class="leader-bio">{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section class="philosophy">
      <div class="container philosophy-inner">
        <div class="kicker philosophy-kicker">Our Philosophy</div>
        <p class="philosophy-copy">
          The team that wins your work is the team that builds it. No bait and switch — senior
          people, start to finish.
        </p>
        <a href="/careers" class="btn btn--outline philosophy-btn">Join the Team</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .leader {
    background: #ffffff;
    padding: clamp(72px, 9vw, 100px) 0 var(--section-pad);
  }

  .leader-grid {
    display: grid;
    grid-template-columns: minmax(300px, 0.72fr) 1fr;
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
  }

  .portrait-slot {
    width: 100%;
    height: 560px;
    background: var(--color-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 108px;
  }

  .portrait-slot::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-gold);
  }

  .portrait-mark {
    width: 130px;
    height: auto;
    opacity: 0.4;
  }

  .leader-kicker {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .kicker-dash {
    display: inline-block;
    width: 40px;
    height: 2px;
    background: var(--color-gold);
  }

  .leader-kicker .kicker {
    letter-spacing: 0.3em;
    font-size: 12px;
  }

  .leader-name {
    margin: 0 0 28px;
    font-size: clamp(30px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--color-ink);
  }

  .leader-bio {
    margin: 0 0 20px;
    font-size: 16.5px;
    line-height: 1.85;
    color: var(--color-stone);
    max-width: 640px;
  }

  .leader-bio:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 899px) {
    .leader-grid {
      grid-template-columns: 1fr;
    }

    .portrait-slot {
      position: static;
      height: clamp(320px, 64vw, 460px);
      max-width: 460px;
    }
  }

  .philosophy {
    background: var(--color-ink);
    padding: clamp(72px, 9vw, 100px) 0;
  }

  .philosophy-inner {
    text-align: center;
  }

  .philosophy-kicker {
    letter-spacing: 0.3em;
    margin-bottom: 24px;
  }

  .philosophy-copy {
    margin: 0 auto;
    font-size: clamp(24px, 2.6vw, 34px);
    font-weight: 600;
    line-height: 1.45;
    color: #ffffff;
    max-width: 860px;
  }

  .philosophy-btn {
    margin-top: 44px;
  }
</style>
