---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import ImageBand from "../components/ImageBand.astro";
import bandPhoto from "../assets/photos/19-warehouse-loading-dock.png";
import multiFamilyPhoto from "../assets/photos/work-areas/01-multi-family-developments.png";
import apartmentPhoto from "../assets/photos/work-areas/02-apartment-communities.png";
import mixedUsePhoto from "../assets/photos/work-areas/03-mixed-use-developments.png";
import officePhoto from "../assets/photos/work-areas/04-office-buildings.png";
import campusPhoto from "../assets/photos/work-areas/05-commercial-campuses.png";

interface PriorityIndustry {
  id: string;
  title: string;
  copy: string;
  image: ImageMetadata;
  alt: string;
  href?: string;
}

const priorityIndustries: PriorityIndustry[] = [
  {
    id: "multi-family-developments",
    title: "Multi-Family Developments",
    copy: "Ground-up communities planned around repeatable quality, coordinated unit delivery, and dependable turnover schedules.",
    image: multiFamilyPhoto,
    alt: "Trinity Build Co. team at a branded multi-family development jobsite in Phoenix",
    href: "/industries/multi-family-developments",
  },
  {
    id: "apartment-communities",
    title: "Apartment Communities",
    copy: "Apartment projects managed from sitework through amenities and punch, with disciplined sequencing across every building.",
    image: apartmentPhoto,
    alt: "Trinity Build Co. team overseeing an apartment community under construction in Phoenix",
    href: "/industries/apartment-communities",
  },
  {
    id: "mixed-use-developments",
    title: "Mixed-Use Developments",
    copy: "Complex residential, retail, and office programs coordinated as one build with aligned budgets, milestones, and stakeholders.",
    image: mixedUsePhoto,
    alt: "Trinity Build Co. team at a mixed-use development under construction in Phoenix",
  },
  {
    id: "office-buildings",
    title: "Office Buildings",
    copy: "Ground-up offices, corporate environments, and professional buildouts delivered for long-term performance and flexibility.",
    image: officePhoto,
    alt: "Trinity Build Co. team at a commercial office building jobsite in Phoenix",
  },
  {
    id: "commercial-campuses",
    title: "Commercial Campuses",
    copy: "Multi-building commercial sites coordinated across infrastructure, shared amenities, phased occupancy, and future growth.",
    image: campusPhoto,
    alt: "Trinity Build Co. team at a commercial campus under construction in Phoenix",
  },
];

const additionalIndustries = [
  {
    title: "Medical",
    copy: "Clinics, outpatient facilities, and medical suites built to healthcare standards and compliance requirements.",
  },
  {
    title: "Industrial",
    copy: "Manufacturing and flex space engineered for uptime, utilities, and future expansion.",
  },
  {
    title: "Warehouses",
    copy: "Distribution and logistics facilities built for throughput — clear heights, dock flow, and durable slabs.",
  },
  {
    title: "Retail",
    copy: "Storefronts, shell buildings, and multi-tenant centers that open on schedule.",
  },
  {
    title: "Restaurants",
    copy: "Kitchens, hoods, and dining rooms delivered ready for service — health-code clean and on time for opening day.",
  },
  {
    title: "Churches",
    copy: "Worship and community spaces built with care, stewardship, and respect for every dollar given.",
  },
  {
    title: "Commercial Condominiums",
    copy: "Ownable commercial space with clean unit turnover and association-ready documentation.",
  },
  {
    title: "Tenant Improvements",
    copy: "Interior transformations in occupied buildings — fast, clean, and coordinated around your operations.",
  },
];
---

<Base
  title="Industries — Trinity Build Co."
  description="Commercial construction for multi-family developments, apartment communities, mixed-use developments, office buildings, commercial campuses, and other sectors across Arizona."
>
  <Nav active="industries" />
  <main id="main-content">
    <PageHero
      eyebrow="Where We Build"
      title="Industries we serve."
      lede="Focused experience across the multi-family, mixed-use, office, and commercial sectors driving Arizona's growth — each with its own codes, constraints, and stakeholders."
    />

    <ImageBand
      image={bandPhoto}
      alt="Trinity Build Co. crew at a commercial warehouse loading dock"
      height="clamp(300px, 38vw, 480px)"
      gradient="linear-gradient(180deg, rgba(13,13,13,0.5) 0%, rgba(13,13,13,0.12) 42%, rgba(13,13,13,0.66) 100%)"
      caption="From loading docks to lobbies — the range to build it, the focus to build it right."
      captionMaxWidth="680px"
    />

    <section class="priority-sectors">
      <div class="container">
        <div class="priority-head" data-reveal>
          <div>
            <div class="eyebrow priority-eyebrow"><span>Core Project Types</span></div>
            <h2 class="section-title priority-title">Built for Arizona's growth.</h2>
          </div>
          <p>
            Representative imagery of the commercial work Trinity Build Co. is positioned to plan,
            manage, and deliver throughout the Phoenix market.
          </p>
        </div>
        <div class="priority-grid">
          {
            priorityIndustries.map((industry) => (
              <article id={industry.id} class="priority-card" data-reveal>
                <Image
                  src={industry.image}
                  alt={industry.alt}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 760px) 48vw, 100vw"
                  quality={75}
                  class="priority-img"
                />
                <div class="priority-copy">
                  <h3>{industry.title}</h3>
                  <p>{industry.copy}</p>
                  {
                    industry.href && (
                      <a href={industry.href} class="priority-link">
                        Explore {industry.title} →
                      </a>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="industry-detail">
      <div class="container">
        <div class="additional-head" data-reveal>
          <div class="eyebrow additional-eyebrow"><span>Additional Experience</span></div>
          <h2 class="section-title additional-title">More commercial sectors.</h2>
        </div>
        <div class="tile-grid industry-grid">
          {
            additionalIndustries.map((industry) => (
              <div class="industry-card" data-reveal>
                <span class="industry-dot" aria-hidden="true" />
                <h3>{industry.title}</h3>
                <p>{industry.copy}</p>
              </div>
            ))
          }
          <a href="/contact" class="industry-cta" data-reveal>
            <div>
              <div class="cta-hint">Don't see your sector?</div>
              <h3 class="cta-title">Tell us about your project</h3>
            </div>
            <span class="cta-link">Let's Talk →</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .priority-sectors {
    background: var(--color-sage-soft);
    padding: var(--section-pad) 0;
  }

  .priority-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 48px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .priority-eyebrow,
  .additional-eyebrow {
    margin-bottom: 24px;
  }

  .priority-title,
  .additional-title {
    color: var(--color-ink);
  }

  .priority-head > p {
    margin: 0;
    max-width: 430px;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-stone-muted);
  }

  .priority-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 24px;
  }

  .priority-card {
    grid-column: span 2;
    background: #ffffff;
    scroll-margin-top: 100px;
  }

  .priority-card:nth-child(-n + 2) {
    grid-column: span 3;
  }

  .priority-img {
    width: 100%;
    height: 270px;
    object-fit: cover;
    display: block;
  }

  .priority-card:nth-child(-n + 2) .priority-img {
    height: 330px;
  }

  .priority-copy {
    padding: 30px 30px 34px;
  }

  .priority-copy h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .priority-copy p {
    margin: 14px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-stone-muted);
  }

  .priority-link {
    display: inline-block;
    margin-top: 20px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--color-sage);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-ink);
  }

  .priority-link:hover {
    color: var(--color-sage-dark);
  }

  @media (max-width: 899px) {
    .priority-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .priority-card,
    .priority-card:nth-child(-n + 2) {
      grid-column: span 1;
    }

    .priority-card:last-child {
      grid-column: 1 / -1;
    }

    .priority-img,
    .priority-card:nth-child(-n + 2) .priority-img {
      height: clamp(240px, 38vw, 330px);
    }
  }

  @media (max-width: 559px) {
    .priority-grid {
      grid-template-columns: 1fr;
    }

    .priority-card,
    .priority-card:nth-child(-n + 2),
    .priority-card:last-child {
      grid-column: 1;
    }

    .priority-img,
    .priority-card:nth-child(-n + 2) .priority-img {
      height: clamp(220px, 58vw, 300px);
    }

    .priority-copy {
      padding: 26px 24px 30px;
    }
  }

  .industry-detail {
    background: #ffffff;
    padding: clamp(72px, 9vw, 100px) 0 var(--section-pad);
  }

  .additional-head {
    margin-bottom: 48px;
  }

  .industry-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(340px, 100%), 1fr));
  }

  .industry-card {
    background: #ffffff;
    padding: 42px 40px;
  }

  .industry-dot {
    display: block;
    width: 7px;
    height: 7px;
    background: var(--color-sage);
  }

  .industry-card h3 {
    margin: 24px 0 12px;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .industry-card p {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-stone-muted);
  }

  .industry-cta {
    background: var(--color-sage);
    padding: 42px 40px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 40px;
    transition: background 0.2s;
  }

  .industry-cta:hover {
    background: var(--color-sage-light);
  }

  .cta-hint {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .cta-title {
    margin: 16px 0 0;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .cta-link {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
</style>
