---
interface Row {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  rows: Row[];
  large?: boolean;
}

const { rows, large = false } = Astro.props;
---

<div class:list={["contact-rows", { "contact-rows--lg": large }]}>
  {
    rows.map((row) => (
      <div class="contact-row">
        <span class="row-label">{row.label}</span>
        {row.href ? (
          <a href={row.href} class="row-value">
            {row.value}
          </a>
        ) : (
          <span class="row-value">{row.value}</span>
        )}
      </div>
    ))
  }
</div>

<style>
  .contact-row {
    border-top: 1px solid var(--color-coal-row);
    padding: 20px 0;
    display: flex;
    gap: 32px;
    align-items: baseline;
  }

  .contact-rows--lg .contact-row {
    padding: 22px 0;
  }

  .contact-row:last-child {
    border-bottom: 1px solid var(--color-coal-row);
  }

  .row-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-dust-label);
    width: 72px;
    flex-shrink: 0;
  }

  .row-value {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .contact-rows--lg .row-value {
    font-size: 17px;
  }

  a.row-value {
    transition: color 0.2s;
  }

  a.row-value:hover {
    color: var(--color-gold);
  }
</style>
