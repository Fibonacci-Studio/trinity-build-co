---
import { business, projectTypes } from "../config";

interface Props {
  rows?: number;
}

const { rows = 5 } = Astro.props;
---

<div class="form-wrap" data-contact-form data-endpoint={business.formEndpoint}>
  <form class="contact-form" novalidate>
    <input
      type="text"
      name="name"
      placeholder="Full name*"
      required
      aria-label="Full name"
      autocomplete="name"
      maxlength="100"
    />
    <input
      type="text"
      name="company"
      placeholder="Company"
      aria-label="Company"
      autocomplete="organization"
      maxlength="120"
    />
    <input
      type="email"
      name="email"
      placeholder="Email*"
      required
      aria-label="Email"
      autocomplete="email"
      maxlength="160"
    />
    <input
      type="tel"
      name="phone"
      placeholder="Phone"
      aria-label="Phone"
      autocomplete="tel"
      maxlength="40"
    />

    <!-- Project type — custom themed dropdown. The native select stays as the
         form value holder and no-JS fallback; JS swaps in the styled listbox. -->
    <div class="select-field span-2" data-custom-select>
      <select name="type" aria-label="Project type">
        <option value="">Project type</option>
        {projectTypes.map((t) => <option value={t.value}>{t.label}</option>)}
      </select>
      <button
        type="button"
        class="select-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        hidden
      >
        <span class="select-value" data-placeholder="Project type">Project type</span>
        <svg
          class="select-chevron"
          width="12"
          height="8"
          viewBox="0 0 12 8"
          fill="none"
          aria-hidden="true"
        >
          <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.6"></path>
        </svg>
      </button>
      <ul class="select-menu" role="listbox" aria-label="Project type" tabindex="-1" hidden>
        {
          projectTypes.map((t, i) => (
            <li role="option" id={`type-opt-${t.value}-${i}`} data-value={t.value} aria-selected="false">
              {t.label}
            </li>
          ))
        }
      </ul>
    </div>

    <textarea
      name="message"
      rows={rows}
      placeholder="Tell us about your project — location, size, timeline"
      aria-label="Project details"
      class="span-2"
      maxlength="4000"></textarea>
    <p class="hp-field" aria-hidden="true">
      <label>
        Leave this field empty
        <input type="text" name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </p>
    <p class="form-error span-2" role="alert" hidden></p>
    <button type="submit" class="btn btn--sage span-2">Request a Proposal</button>
  </form>

  <div class="form-success" hidden>
    <div class="success-check" aria-hidden="true">✓</div>
    <div class="success-title">Request received</div>
    <p class="success-copy">
      Thank you — a member of our team will reach out within one business day.
    </p>
  </div>
</div>

<style>
  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    background: var(--color-coal-input);
    border: 1px solid var(--color-coal-border);
    color: #ffffff;
    padding: 16px;
    font-size: 14px;
    width: 100%;
    border-radius: 0;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--color-sage-light);
    outline: none;
  }

  .span-2 {
    grid-column: 1 / -1;
  }

  /* ── Custom select ── */
  .select-field {
    position: relative;
  }

  .select-field select {
    appearance: none;
  }

  .select-field.is-enhanced select {
    display: none;
  }

  .select-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    background: var(--color-coal-input);
    border: 1px solid var(--color-coal-border);
    padding: 16px;
    font-size: 14px;
    color: #ffffff;
    cursor: pointer;
    text-align: left;
  }

  .select-trigger:focus-visible {
    border-color: var(--color-sage-light);
    outline: none;
  }

  .select-trigger[aria-expanded="true"] {
    border-color: var(--color-sage-light);
  }

  .select-value.is-placeholder {
    color: var(--color-dust-faint);
  }

  .select-chevron {
    color: var(--color-gold);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .select-trigger[aria-expanded="true"] .select-chevron {
    transform: rotate(180deg);
  }

  .select-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    padding: 6px 0;
    list-style: none;
    background: var(--color-coal-input);
    border: 1px solid var(--color-coal-border);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.55);
    max-height: 288px;
    overflow-y: auto;
  }

  .select-menu:focus {
    outline: none;
  }

  .select-menu li {
    padding: 13px 16px;
    font-size: 14px;
    color: var(--color-dust-nav);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
  }

  .select-menu li.is-active {
    background: var(--color-coal-hover);
    color: #ffffff;
  }

  .select-menu li[aria-selected="true"] {
    color: var(--color-sage-light);
  }

  .select-menu li[aria-selected="true"]::after {
    content: "✓";
    float: right;
    font-weight: 700;
  }

  .contact-form .btn {
    padding: 19px;
    width: 100%;
  }

  .contact-form .btn[disabled] {
    opacity: 0.65;
    cursor: default;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    margin: 0;
  }

  .form-error {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: #e08f7c;
  }

  .form-success {
    border: 1px solid var(--color-coal-border);
    padding: 64px 48px;
    text-align: center;
  }

  .success-check {
    font-size: 28px;
    color: var(--color-sage-light);
    font-weight: 700;
  }

  .success-title {
    margin-top: 20px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .success-copy {
    margin: 14px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-dust-muted);
  }

  @media (max-width: 560px) {
    .contact-form {
      grid-template-columns: 1fr;
    }

    .span-2 {
      grid-column: auto;
    }

    .form-success {
      padding: 48px 28px;
    }

    /* 16px inputs prevent iOS Safari's auto-zoom on focus */
    .contact-form input,
    .contact-form select,
    .contact-form textarea,
    .select-trigger,
    .select-menu li {
      font-size: 16px;
    }
  }
</style>

<script>
  // ── Custom select (button + listbox), synced to the hidden native select ──
  document.querySelectorAll<HTMLElement>("[data-custom-select]").forEach((field) => {
    const select = field.querySelector<HTMLSelectElement>("select");
    const trigger = field.querySelector<HTMLButtonElement>(".select-trigger");
    const valueEl = field.querySelector<HTMLElement>(".select-value");
    const menu = field.querySelector<HTMLUListElement>(".select-menu");
    const options = Array.from(field.querySelectorAll<HTMLLIElement>("[role=option]"));
    if (!select || !trigger || !valueEl || !menu || !options.length) return;

    field.classList.add("is-enhanced");
    trigger.hidden = false;
    valueEl.classList.add("is-placeholder");
    let activeIndex = -1;

    const setActive = (index: number) => {
      activeIndex = Math.max(0, Math.min(index, options.length - 1));
      options.forEach((opt, i) => opt.classList.toggle("is-active", i === activeIndex));
      menu.setAttribute("aria-activedescendant", options[activeIndex].id);
      options[activeIndex].scrollIntoView({ block: "nearest" });
    };

    const open = () => {
      menu.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      const selected = options.findIndex((opt) => opt.getAttribute("aria-selected") === "true");
      setActive(selected >= 0 ? selected : 0);
      menu.focus();
    };

    const close = (refocus = false) => {
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      if (refocus) trigger.focus();
    };

    const choose = (index: number) => {
      const opt = options[index];
      select.value = opt.dataset.value || "";
      options.forEach((o) => o.setAttribute("aria-selected", String(o === opt)));
      valueEl.textContent = opt.textContent?.trim() || "";
      valueEl.classList.remove("is-placeholder");
      close(true);
    };

    trigger.addEventListener("click", () => (menu.hidden ? open() : close()));
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "ArrowUp") {
        e.preventDefault();
        open();
      }
    });

    options.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(i));
      opt.addEventListener("mousemove", () => setActive(i));
    });

    menu.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(activeIndex + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(activeIndex - 1);
      } else if (e.key === "Home") {
        e.preventDefault();
        setActive(0);
      } else if (e.key === "End") {
        e.preventDefault();
        setActive(options.length - 1);
      } else if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        choose(activeIndex);
      } else if (e.key === "Escape") {
        e.preventDefault();
        close(true);
      } else if (e.key === "Tab") {
        close();
      }
    });

    document.addEventListener("click", (e) => {
      if (!menu.hidden && !field.contains(e.target as Node)) close();
    });
  });

  // ── Submit flow ──
  document.querySelectorAll<HTMLElement>("[data-contact-form]").forEach((wrap) => {
    const form = wrap.querySelector<HTMLFormElement>("form");
    const success = wrap.querySelector<HTMLElement>(".form-success");
    const errorEl = wrap.querySelector<HTMLElement>(".form-error");
    const button = wrap.querySelector<HTMLButtonElement>("button[type=submit]");
    const endpoint = wrap.dataset.endpoint || "/api/contact";
    if (!form || !success || !button) return;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;

      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = "";
      }
      button.disabled = true;
      button.textContent = "Sending…";

      try {
        const payload = Object.fromEntries(new FormData(form).entries());
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const out = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
        if (!res.ok || !out.ok) throw new Error(out.error || "Something went wrong.");
        form.hidden = true;
        success.hidden = false;
      } catch (err) {
        if (errorEl) {
          errorEl.textContent =
            err instanceof Error && err.message !== "Failed to fetch"
              ? err.message
              : "Something went wrong sending your request. Please try again, or email us directly.";
          errorEl.hidden = false;
        }
        button.disabled = false;
        button.textContent = "Request a Proposal";
      }
    });
  });
</script>
