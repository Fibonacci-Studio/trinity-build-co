---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  height?: string;
  gradient?: string;
  objectPosition?: string;
  eyebrow?: string;
  caption: string;
  captionMaxWidth?: string;
}

const {
  image,
  alt,
  height = "clamp(320px, 42vw, 520px)",
  gradient = "linear-gradient(180deg, rgba(13,13,13,0.55) 0%, rgba(13,13,13,0.1) 40%, rgba(13,13,13,0.72) 100%)",
  objectPosition = "center 50%",
  eyebrow,
  caption,
  captionMaxWidth = "640px",
} = Astro.props;
---

<section class="image-band" style={`height:${height}`}>
  <Image
    src={image}
    alt={alt}
    widths={[768, 1280, 1920]}
    sizes="100vw"
    quality={72}
    class="band-img"
    style={`object-position:${objectPosition}`}
  />
  <div class="band-scrim" aria-hidden="true" style={`background:${gradient}`}></div>
  <div class="band-content">
    <div class="container">
      {
        eyebrow && (
          <div class="eyebrow band-eyebrow">
            <span>{eyebrow}</span>
          </div>
        )
      }
      <p class="band-caption" style={`max-width:${captionMaxWidth}`}>{caption}</p>
    </div>
  </div>
</section>

<style>
  .image-band {
    position: relative;
    overflow: hidden;
  }

  .band-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .band-scrim {
    position: absolute;
    inset: 0;
  }

  .band-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding-bottom: 48px;
  }

  .band-eyebrow {
    margin-bottom: 16px;
  }

  .band-eyebrow span {
    letter-spacing: 0.28em;
  }

  .band-caption {
    margin: 0;
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 600;
    line-height: 1.35;
    color: #ffffff;
  }
</style>
