---
import { Image } from "astro:assets";
import logoIcon from "../assets/logo-icon.png";
import { business, navLinks, type NavKey } from "../config";

interface Props {
  active?: NavKey;
  showTopBar?: boolean;
}

const { active = "none", showTopBar = true } = Astro.props;
---

{
  showTopBar && (
    <div class="top-bar">
      <div class="container top-bar-inner">
        <span class="top-bar-label">Phoenix, Arizona — Commercial General Contractor</span>
        <span class="top-bar-right">
          <a href={business.phoneHref} class="top-bar-phone">{business.phone}</a>
          <span class="top-bar-divider" aria-hidden="true"></span>
          <span class="top-bar-label top-bar-domain">{business.domainLabel}</span>
        </span>
      </div>
    </div>
  )
}

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Trinity Build Co. — home">
      <Image src={logoIcon} alt="" width={49} height={30} densities={[1, 2]} class="brand-mark" loading="eager" />
      <span class="brand-lockup">
        <span class="brand-name">TRINITY</span>
        <span class="brand-sub">BUILD CO.</span>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { "is-active": active === link.key }]}
            aria-current={active === link.key ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a href="/contact" class="nav-cta">Schedule a Consultation</a>
    </nav>

    <button
      id="menu-btn"
      class="menu-btn"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" inert>
    <nav class="container mobile-menu-inner" aria-label="Mobile navigation">
      {
        navLinks.map((link) => (
          <a href={link.href} class:list={["mobile-link", { "is-active": active === link.key }]}>
            {link.label}
          </a>
        ))
      }
      <a href="/contact" class="mobile-link">Contact</a>
      <div class="mobile-menu-foot">
        <a href="/contact" class="btn btn--gold">Schedule a Consultation</a>
        <a href={business.phoneHref} class="mobile-phone">{business.phone}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .top-bar {
    background: var(--color-ink);
    border-bottom: 1px solid var(--color-coal-nav);
  }

  .top-bar-inner {
    padding-block: 11px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .top-bar-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dust-label);
  }

  .top-bar-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .top-bar-phone {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    text-decoration: none;
  }

  .top-bar-divider {
    width: 1px;
    height: 12px;
    background: var(--color-coal-border);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 13, 13, 0.98);
    border-bottom: 1px solid var(--color-coal-nav);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .header-inner {
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 13px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-mark {
    height: 30px;
    width: auto;
    display: block;
  }

  .brand-lockup {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .brand-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: #ffffff;
    line-height: 1;
  }

  .brand-sub {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.42em;
    color: var(--color-gold);
    line-height: 1;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dust-nav);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  .nav-link.is-active {
    color: var(--color-gold);
  }

  .nav-cta {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
    background: var(--color-gold);
    padding: 13px 24px;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: var(--color-gold-light);
  }

  .menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .menu-btn span {
    display: block;
    height: 2px;
    width: 100%;
    background: #ffffff;
    transition:
      transform 0.25s,
      opacity 0.25s;
  }

  .menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-btn[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-ink);
    border-bottom: 1px solid var(--color-coal-nav);
    max-height: calc(100dvh - 76px);
    overflow-y: auto;
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    padding-block: 12px 32px;
  }

  .mobile-link {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-dust-nav);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-coal-nav);
  }

  .mobile-link.is-active {
    color: var(--color-gold);
  }

  .mobile-menu-foot {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 28px;
  }

  .mobile-phone {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    text-decoration: none;
    text-align: center;
  }

  @media (max-width: 1219px) {
    .desktop-nav {
      display: none;
    }

    .menu-btn {
      display: flex;
    }
  }

  @media (max-width: 700px) {
    .top-bar-domain,
    .top-bar-divider {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .top-bar-inner {
      justify-content: center;
    }

    .top-bar-label {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  const links = Array.from(menu?.querySelectorAll("a") ?? []);
  let open = false;

  const syncMenuHeight = () => {
    if (!menu) return;
    const availableHeight = Math.max(0, window.innerHeight - menu.getBoundingClientRect().top);
    menu.style.maxHeight = `${availableHeight}px`;
  };

  const setMenu = (next: boolean, returnFocus = false) => {
    open = next;
    btn?.setAttribute("aria-expanded", String(open));
    menu?.classList.toggle("is-open", open);
    document.body.classList.toggle("nav-open", open);
    if (open) {
      syncMenuHeight();
      menu?.removeAttribute("inert");
      links[0]?.focus();
    } else {
      menu?.setAttribute("inert", "");
      menu?.style.removeProperty("max-height");
      if (returnFocus) btn?.focus();
    }
  };

  btn?.addEventListener("click", () => setMenu(!open));
  links.forEach((link) => link.addEventListener("click", () => setMenu(false)));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && open) setMenu(false, true);
  });
  window.addEventListener(
    "resize",
    () => {
      if (window.innerWidth >= 1220 && open) setMenu(false);
      else if (open) syncMenuHeight();
    },
    { passive: true }
  );
</script>
